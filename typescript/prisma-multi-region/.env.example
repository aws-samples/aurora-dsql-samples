# Primary DSQL cluster endpoint
CLUSTER_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws

# Secondary (peer) DSQL cluster endpoint for failover
CLUSTER_ENDPOINT_SECONDARY=your-cluster-id.dsql.us-west-2.on.aws

# DSQL user (admin or custom role)
CLUSTER_USER=admin

# Region this app instance runs in
AWS_REGION=us-east-1

# Server port
PORT=3000
