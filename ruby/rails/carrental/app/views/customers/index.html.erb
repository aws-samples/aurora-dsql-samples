<% content_for(:title) { "Customers" } %>

<div class="page-header">
  <h1>Customers</h1>
  <%= link_to "New Customer", new_customer_path, class: "btn btn-primary" %>
</div>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>License Number</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @customers.each do |customer| %>
        <tr>
          <td><%= link_to customer.name, customer %></td>
          <td><%= customer.email %></td>
          <td><%= customer.phone || "—" %></td>
          <td><%= customer.license_number %></td>
          <td class="actions">
            <%= link_to "Edit", edit_customer_path(customer), class: "btn btn-secondary btn-sm" %>
            <%= button_to "Delete", customer_path(customer), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Are you sure?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
